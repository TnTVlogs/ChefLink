# ================================================================
# ChefLink - Fitxer de configuració d'entorn
# Copia aquest fitxer com a ".env" i omple els valors reals.
# MAI pugis el fitxer ".env" a git (ja està al .gitignore).
# ================================================================

# --- JWT (obligatori per autenticació segura) ---
# Canvia per un string llarg i aleatori (mínim 32 caràcters)
JWT_SECRET=canvia_per_un_secret_llarg_i_aleatori
JWT_ISSUER=cheflink-server
JWT_AUDIENCE=cheflink-clients

# --- Admin Bootstrap ---
# Contrasenya de l'usuari "admin" creat automàticament en el primer arrancada.
# Si no s'especifica, es genera aleatòriament i es mostra als logs del servidor.
ADMIN_PASSWORD=canvia_per_una_contrasenya_segura

# --- Base de dades ---
# Per defecte usa SQLite local (fitxer cheflink.db al directori de treball).
# Descomenta per usar MariaDB en entorns de producció:
# DB_URL=jdbc:mariadb://localhost:3306/cheflink
# DB_USER=cheflinkuser
# DB_PASSWORD=passwordSuperSegur

# --- Servidor ---
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
